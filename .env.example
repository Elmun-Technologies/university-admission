# =========================================
# Docker & Server Settings
# =========================================
# Unique project name (used as a prefix for docker containers)
PROJECT_NAME=university_admission
# The port on the host machine mapping to the Nginx web container
NGINX_PORT=8000

# =========================================
# Database Settings
# =========================================
# The hostname of the database (matches the service name in docker-compose)
DB_HOST=mariadb
# Port used by the database container
DB_PORT=3306
# Database name for this specific university
DB_DATABASE=university_admission
# Database user name
DB_USERNAME=uni_user
# Password for the database user
DB_PASSWORD=secret
# Root password for MariaDB container initialization
DB_ROOT_PASSWORD=root_secret

# =========================================
# Application Settings
# =========================================
# Set to 'dev' for development and testing, 'prod' for production
YII_ENV=dev
# Enable (true) or disable (false) debugging features and error traces
YII_DEBUG=true
# The main contact email for the admission system administrator
ADMIN_EMAIL=admin@university-admission.uz
# The email address used to send out system emails
SUPPORT_EMAIL=support@university-admission.uz
# Application wide cookie validation key (must be randomly generated for each deployment)
COOKIE_VALIDATION_KEY=ReplaceWithRandomString123

# =========================================
# Telegram Settings
# =========================================
# Telegram Bot API Token from BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIJklmNOPQrsTUVwxyz
# The chat ID of the admission staff group/channel to receive notifications
TELEGRAM_CHAT_ID=-1001234567890

# =========================================
# CRM Settings (amoCRM)
# =========================================
# Subdomain of the amoCRM account (e.g., if url is university.amocrm.ru, enter 'university')
AMOCRM_SUBDOMAIN=university
# Long-lived access token or integration secret for amoCRM API
AMOCRM_CLIENT_ID=your_client_id
AMOCRM_CLIENT_SECRET=your_client_secret
AMOCRM_AUTH_CODE=your_auth_code
AMOCRM_REDIRECT_URI=https://your-domain.com/admin/crm/auth

# =========================================
# Backup Settings
# =========================================
# Enable automated backups (true/false)
BACKUP_ENABLED=true
# Frequency of backups (daily, weekly)
BACKUP_FREQUENCY=daily
# Number of backups to retain before deletion
BACKUP_RETENTION_DAYS=7
# Local storage path for backups
BACKUP_PATH=/path/to/backups
